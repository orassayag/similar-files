{
  "name": "similar-files",
  "version": "1.0.0",
  "private": false,
  "description": "A TypeScript CLI tool that recursively scans directories to detect and optionally remove similar files using name containment (case-sensitive, same ext) and configurable size tolerance. It analyzes patterns, compares sizes, flags duplicates, and offers cleanup with reporting for safe file management",
  "keywords": [
    "duplicate-files",
    "similar-files",
    "cleanup",
    "disk-space",
    "cli",
    "typescript",
    "filesystem",
    "developer-tools",
    "nodejs",
    "file-management"
  ],
  "homepage": "https://github.com/orassayag/similar-files#readme",
  "bugs": {
    "url": "https://github.com/orassayag/similar-files/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/orassayag/similar-files.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/orassayag"
  },
  "license": "MIT",
  "author": {
    "name": "Or Assayag",
    "email": "orassayag@gmail.com",
    "url": "https://github.com/orassayag"
  },
  "contributors": [
    {
      "name": "Or Assayag",
      "email": "orassayag@gmail.com",
      "url": "https://github.com/orassayag"
    }
  ],
  "type": "module",
  "main": "src/index.ts",
  "files": [
    ".github",
    ".pnpm-store",
    ".vscode",
    "dist",
    "src",
    "test-data",
    ".gitignore",
    ".npmrc",
    ".prettierrc",
    ".prettierrc.json",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "eslint.config.mjs",
    "INSTRUCTIONS.md",
    "LICENSE",
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "README.md",
    "SECURITY.md",
    "tsconfig.json",
    "tsconfig.node.json",
    "vitest.config.ts"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prettier": "prettier --check 'src/**/*.ts'",
    "prettier:fix": "prettier --write 'src/**/*.ts'",
    "start": "tsx src/main.ts",
    "test": "cross-env NODE_OPTIONS='--no-warnings' vitest run --coverage",
    "test:no-coverage": "cross-env NODE_OPTIONS='--no-warnings' vitest run",
    "test:watch": "cross-env NODE_OPTIONS='--no-warnings' vitest"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-istanbul": "^4.1.9",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
